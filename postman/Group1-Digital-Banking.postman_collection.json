{
  "info": {
    "name": "Group1 Digital Banking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Group 1 auth and customer APIs with basic automated Postman tests"
  },
  "item": [
    {
      "name": "1 - Register User",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });",
          "if (pm.response.code === 201) {",
          "  const json = pm.response.json();",
          "  pm.test('passwordHash is absent', function () { pm.expect(json.passwordHash).to.eql(undefined); });",
          "}"
        ]}
      }]
    },
    {
      "name": "2 - Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
          "const json = pm.response.json();",
          "pm.environment.set('accessToken', json.accessToken);",
          "pm.test('Token fields exist', function () {",
          "  pm.expect(json.accessToken).to.be.a('string');",
          "  pm.expect(json.refreshToken).to.be.a('string');",
          "  pm.expect(json.tokenType).to.eql('Bearer');",
          "  pm.expect(json.expiresIn).to.be.a('number');",
          "});"
        ]}
      }]
    },
    {
      "name": "3 - Create Customer",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{accessToken}}"}
        ],
        "url": "{{baseUrl}}/api/customers",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"address\": \"123 Main St, Toronto, ON\",\n  \"type\": \"PERSON\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
          "const json = pm.response.json();",
          "pm.environment.set('customerId', json.customerId);",
          "pm.test('accounts array starts empty', function () { pm.expect(json.accounts).to.be.an('array'); });"
        ]}
      }]
    },
    {
      "name": "4 - Get Customer",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
        "url": "{{baseUrl}}/api/customers/{{customerId}}"
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
        ]}
      }]
    },
    {
      "name": "5 - Update Customer",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{accessToken}}"}
        ],
        "url": "{{baseUrl}}/api/customers/{{customerId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Smith\",\n  \"address\": \"456 New St, Toronto, ON\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
          "const json = pm.response.json();",
          "pm.test('Name updated', function () { pm.expect(json.name).to.eql('Jane Smith'); });"
        ]}
      }]
    },
    {
      "name": "Negative - Invalid Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {"mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"Wrong@123\"\n}"}
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 401', function () { pm.response.to.have.status(401); });",
          "const json = pm.response.json();",
          "pm.test('Generic invalid credentials response', function () { pm.expect(json.code).to.eql('INVALID_CREDENTIALS'); });"
        ]}
      }]
    },
    {
      "name": "Negative - Immutable Field Update",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{accessToken}}"}
        ],
        "url": "{{baseUrl}}/api/customers/{{customerId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane New\",\n  \"email\": \"blocked@example.com\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {"type": "text/javascript", "exec": [
          "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
          "const json = pm.response.json();",
          "pm.test('Field not updatable', function () { pm.expect(json.code).to.eql('FIELD_NOT_UPDATABLE'); });"
        ]}
      }]
    }
  ]
}
